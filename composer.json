{
    "name": "netbrain/wp-delvalle",
    "description": "Funcionalidades personalizadas para delvalle.com",
    "version": "1.0",
    "license": "propietary",
    "type": "wordpress-plugin",
    "authors": [
        {
            "name": "netbrain",
            "email": "info@netbrain.es"
        }
    ],
    "require": {
        "php": ">=8.1.32",
        "haydenpierce/class-finder": "^0.5.3",
        "vlucas/phpdotenv": "v5.6.1",
        "ext-intl": "*",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.11.2",
        "wp-coding-standards/wpcs": "^3.1.0"
    },
    "autoload": {
        "psr-4": {
            "wp_coremanager\\": "includes/classes"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
